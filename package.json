{
  "name": "ts-react-boilerplate",
  "version": "1.0.0",
  "description": "Another basic Typescript, React boilerplate",
  "main": "src/index.tsx",
  "author": "Brendon <frontalspy@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run start:app\" \"npm run start:server\"",
    "start:app": "vite --config ./config/vite.config.ts",
    "start:server": "nodemon --esm ./src/server/index.ts",
    "test": "vitest run --config ./config/vitest.config.ts",
    "format": "biome format --write"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-css-modules": "^1.16.0",
    "vitest": "^4.1.5"
  }
}
